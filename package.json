{
  "name": "prhythm",
  "version": "0.1.0",
  "private": true,
  "description": "瞬作統合モデル — 提案スキル群 + Slidev プレゼンテーション",
  "scripts": {
    "dev": "slidev",
    "build": "slidev build",
    "export": "slidev export",
    "export:pptx": "slidev export --format pptx",
    "export:pdf": "slidev export --format pdf",
    "export:png": "slidev export --format png",
    "docs:sync": "node scripts/sync-docs.mjs",
    "docs:dev": "npm run dev --prefix docs-site",
    "docs:build": "npm run build --prefix docs-site"
  },
  "devDependencies": {
    "@slidev/cli": "^51.0.0",
    "@slidev/theme-default": "latest",
    "playwright-chromium": "^1.52.0"
  }
}
